{
  "name": "proton",
  "productName": "Proton",
  "version": "1.2.0",
  "description": "Proton — offline learning tracker & knowledge base (Paths · Courses · Notes)",
  "author": {
    "name": "Mostafa Hazem"
  },
  "license": "MIT",
  "main": "src/main/main.js",
  "scripts": {
    "start": "electron .",
    "postinstall": "electron-builder install-app-deps",
    "pack": "electron-builder --dir",
    "dist": "electron-builder --win nsis portable",
    "dist:installer": "electron-builder --win nsis",
    "dist:portable": "electron-builder --win portable"
  },
  "dependencies": {
    "better-sqlite3": "^11.8.1"
  },
  "devDependencies": {
    "electron": "^31.7.6",
    "electron-builder": "^25.1.8"
  },
  "build": {
    "appId": "com.mostafahazem.proton",
    "productName": "Proton",
    "copyright": "Copyright © 2026 Mostafa Hazem",
    "asar": true,
    "asarUnpack": [
      "**/*.node",
      "node_modules/better-sqlite3/**"
    ],
    "files": [
      "src/**/*",
      "build/icon.ico",
      "package.json"
    ],
    "directories": {
      "output": "dist",
      "buildResources": "build"
    },
    "win": {
      "target": [
        "nsis",
        "portable"
      ],
      "icon": "build/icon.ico",
      "artifactName": "${productName}-${version}-${arch}.${ext}"
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "allowElevation": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Proton",
      "installerIcon": "build/icon.ico",
      "uninstallerIcon": "build/icon.ico",
      "deleteAppDataOnUninstall": false,
      "artifactName": "Proton Setup.exe"
    },
    "portable": {
      "artifactName": "Proton Portable.exe"
    }
  }
}
